# REO Identity Foundation is disabled by default.
VITE_REO_IDENTITY_ENABLED=false
REO_IDENTITY_ENABLED=false
REO_SERVER_SESSIONS_ENABLED=false
REO_IDENTITY_DIAGNOSTICS_ENABLED=false
VITE_REO_TRIAL_PROVISIONING_ENABLED=false
REO_TRIAL_PROVISIONING_ENABLED=false

# Firebase Web App values from the separate staging project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin service account values. Never commit real values.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

REO_SESSION_COOKIE_DAYS=7
REO_TRIAL_DAYS=14
